b\u6536\u5f55\u200b\u56fd\u9645\u200b\u7ec4\u7ec7\u200b\u3001\u200b\u5404\u56fd\u200b\u653f\u5e9c\u200b\u53d1\u5e03\u200b\u7684\u200b\u653f\u7b56\u200b\u7814\u7a76\u200b\u62a5\u544a\u200b\u53ca\u200b\u5b66\u672f\u7814\u7a76\u200b\u6587\u732e\u200b\u3002</p>"},{"location":"policy/%E5%9B%BD%E9%99%85%E6%94%BF%E7%AD%96%E7%A0%94%E7%A9%B6/#_2","title":"\u6587\u6863\u200b\u5217\u8868","text":"\u6587\u4ef6\u540d\u200b \u200b\u53d1\u5e03\u200b\u673a\u6784\u200b \u200b\u53d1\u5e03\u200b\u65f6\u95f4\u200b \u200b\u8bf4\u660e\u200b \u200b\u91d1\u878d\u5371\u673a\u200b\u540e\u200b\u7684\u200b\u4ea7\u4e1a\u653f\u7b56\u200b.pdf \u200b\u56fd\u9645\u8d27\u5e01\u57fa\u91d1\u7ec4\u7ec7\u200b (IMF) 2025\u200b\u5e74\u200b10\u200b\u6708\u200b IMF Working Paper WP/25/222"},{"location":"policy/%E5%9B%BD%E9%99%85%E6%94%BF%E7%AD%96%E7%A0%94%E7%A9%B6/#_3","title":"\u5185\u5bb9\u6458\u8981","text":""},{"location":"policy/%E5%9B%BD%E9%99%85%E6%94%BF%E7%AD%96%E7%A0%94%E7%A9%B6/#industrial-policy-since-the-great-financial-crisis","title":"\u91d1\u878d\u5371\u673a\u200b\u540e\u200b\u7684\u200b\u4ea7\u4e1a\u653f\u7b56\u200b (Industrial Policy Since the Great Financial Crisis)","text":"<p>\u200b\u4f5c\u8005\u200b\uff1a Simon Evenett, Adam Jakubik, Jaden Kim, Fernando Mart\u00edn, Samuel Pienknagura, Michele Ruta \u200b\u7b49\u200b IMF \u200b\u5b66\u8005\u200b</p> <p>\u200b\u7814\u7a76\u200b\u65f6\u95f4\u200b\uff1a 2009-2023\u200b\u5e74\u200b</p> <p>\u200b\u4e3b\u8981\u200b\u53d1\u73b0\u200b\uff1a</p> <ul> <li>\u200b\u81ea\u200b\u91d1\u878d\u5371\u673a\u200b\u4ee5\u6765\u200b\uff0c\u200b\u4ea7\u4e1a\u653f\u7b56\u200b\u5728\u200b\u5168\u7403\u200b\u8303\u56f4\u200b\u5185\u200b\u5e7f\u6cdb\u200b\u91c7\u7528\u200b\uff0c\u200b\u4e3b\u8981\u200b\u901a\u8fc7\u200b\u8865\u8d34\u200b\u548c\u200b\u8d38\u6613\u200b\u9650\u5236\u200b\u5b9e\u65bd\u200b</li> <li>2020\u200b\u5e74\u200b\u5de6\u53f3\u200b\u51fa\u73b0\u200b\u7ed3\u6784\u6027\u200b\u8f6c\u6298\u200b\uff0c\u200b\u653f\u7b56\u200b\u6d3b\u52a8\u200b\u52a0\u901f\u200b\uff0c\"\u200b\u65b0\u200b\u4ea7\u4e1a\u653f\u7b56\u200b\"\u200b\u5174\u8d77\u200b</li> <li>\u200b\u65b0\u200b\u4ea7\u4e1a\u653f\u7b56\u200b\u7684\u200b\u9a71\u52a8\u200b\u56e0\u7d20\u200b\uff1a\u200b\u4f9b\u5e94\u94fe\u200b\u97e7\u6027\u200b\u3001\u200b\u56fd\u5bb6\u200b\u5b89\u5168\u200b\u3001\u200b\u5730\u7f18\u200b\u653f\u6cbb\u200b\u5173\u5207\u200b</li> <li>\u200b\u653f\u7b56\u200b\u91cd\u70b9\u200b\uff1a\u200b\u53cc\u91cd\u200b\u7528\u9014\u200b\u6280\u672f\u200b\u3001\u200b\u5148\u8fdb\u200b\u79d1\u6280\u9886\u57df\u200b\u3001\u200b\u5173\u952e\u200b\u539f\u6750\u6599\u200b</li> <li>\u200b\u5730\u7f18\u200b\u653f\u6cbb\u200b\u98ce\u9669\u200b\u548c\u200b\"\u200b\u9488\u950b\u76f8\u5bf9\u200b\"\u200b\u7684\u200b\u62a5\u590d\u200b\u5728\u200b2020\u200b\u5e74\u200b\u540e\u200b\u53d1\u6325\u200b\u4e86\u200b\u66f4\u200b\u5927\u200b\u4f5c\u7528\u200b</li> </ul> <p>\u200b\u5173\u952e\u8bcd\u200b\uff1a \u200b\u4ea7\u4e1a\u653f\u7b56\u200b\u3001IMF\u3001\u200b\u8d38\u6613\u200b\u653f\u7b56\u200b\u3001\u200b\u4f9b\u5e94\u94fe\u200b\u5b89\u5168\u200b\u3001\u200b\u5730\u7f18\u200b\u653f\u6cbb\u200b</p> <p>\ud83d\udce5 \u200b\u4e0b\u8f7d\u200b\u94fe\u63a5\u200b\uff1a \u200b\u91d1\u878d\u5371\u673a\u200b\u540e\u200b\u7684\u200b\u4ea7\u4e1a\u653f\u7b56\u200b.pdf</p> <p>\u200b\u66f4\u200b\u591a\u200b\u56fd\u9645\u200b\u653f\u7b56\u200b\u7814\u7a76\u200b\u6301\u7eed\u200b\u6dfb\u52a0\u200b\u4e2d\u200b...</p>"},{"location":"theory/","title":"\u7406\u8bba\u200b\u6587\u7ae0","text":"<p>\u200b\u672c\u200b\u680f\u76ee\u200b\u5b58\u653e\u200b\u7406\u8bba\u200b\u6587\u7ae0\u200b\u548c\u200b\u7406\u8bba\u200b\u6846\u67b6\u200b\u3002</p>"},{"location":"theory/#_2","title":"\u6587\u7ae0\u200b\u5217\u8868","text":"<p>\uff08\u200b\u6587\u7ae0\u200b\u6301\u7eed\u200b\u6dfb\u52a0\u200b\u4e2d\u200b...\uff09</p> <p>\u200b\u66f4\u200b\u591a\u200b\u6587\u7ae0\u200b\u6301\u7eed\u200b\u6dfb\u52a0\u200b\u4e2d\u200b...</p>"}]}