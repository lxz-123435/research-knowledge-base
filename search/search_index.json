u5e94\u94fe\u200b\u97e7\u6027\u200b\u3001\u200b\u56fd\u5bb6\u200b\u5b89\u5168\u200b\u3001\u200b\u5730\u7f18\u200b\u653f\u6cbb\u200b\u5173\u5207\u200b</li> <li>\u200b\u653f\u7b56\u200b\u91cd\u70b9\u200b\uff1a\u200b\u53cc\u91cd\u200b\u7528\u9014\u200b\u6280\u672f\u200b\u3001\u200b\u5148\u8fdb\u200b\u79d1\u6280\u9886\u57df\u200b\u3001\u200b\u5173\u952e\u200b\u539f\u6750\u6599\u200b</li> <li>\u200b\u5730\u7f18\u200b\u653f\u6cbb\u200b\u98ce\u9669\u200b\u548c\u200b\"\u200b\u9488\u950b\u76f8\u5bf9\u200b\"\u200b\u7684\u200b\u62a5\u590d\u200b\u5728\u200b2020\u200b\u5e74\u200b\u540e\u200b\u53d1\u6325\u200b\u4e86\u200b\u66f4\u200b\u5927\u200b\u4f5c\u7528\u200b</li> </ul> <p>\u200b\u5173\u952e\u8bcd\u200b\uff1a \u200b\u4ea7\u4e1a\u653f\u7b56\u200b\u3001IMF\u3001\u200b\u8d38\u6613\u200b\u653f\u7b56\u200b\u3001\u200b\u4f9b\u5e94\u94fe\u200b\u5b89\u5168\u200b\u3001\u200b\u5730\u7f18\u200b\u653f\u6cbb\u200b</p> <p>\ud83d\udce5 \u200b\u4e0b\u8f7d\u200b\u94fe\u63a5\u200b\uff1a \u200b\u91d1\u878d\u5371\u673a\u200b\u540e\u200b\u7684\u200b\u4ea7\u4e1a\u653f\u7b56\u200b.pdf</p> <p>\u200b\u66f4\u200b\u591a\u200b\u56fd\u9645\u200b\u653f\u7b56\u200b\u7814\u7a76\u200b\u6301\u7eed\u200b\u6dfb\u52a0\u200b\u4e2d\u200b...</p>"},{"location":"policy/ASEAN/","title":"\u4e1c\u76df\u200b\u653f\u7b56","text":""},{"location":"policy/China-env/","title":"\u73af\u5883\u4fdd\u62a4","text":""},{"location":"policy/China-financial/","title":"\u7eff\u8272\u200b\u91d1\u878d","text":""},{"location":"policy/China-ministry-commerce/","title":"\u5546\u52a1\u90e8\u200b\u653f\u7b56\u200b\u6587\u4ef6","text":"<p>\u200b\u5546\u52a1\u90e8\u200b\u53d1\u5e03\u200b\u7684\u200b\u653f\u7b56\u200b\u6587\u4ef6\u200b\u3001\u200b\u62a5\u544a\u200b\u548c\u200b\u6307\u5f15\u200b\u3002</p>"},{"location":"policy/China-ministry-commerce/#_2","title":"\u6587\u4ef6\u200b\u5217\u8868","text":"\u6587\u4ef6\u540d\u200b \u200b\u8bf4\u660e\u200b 2024\u200b\u5e74\u5ea6\u200b\u4e2d\u56fd\u200b\u5bf9\u5916\u200b\u76f4\u63a5\u200b\u6295\u8d44\